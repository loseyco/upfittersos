{
  "name": "saegroup-os-api",
  "version": "1.0.0",
  "description": "SAE Group OS REST API",
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc && copy src\\swagger.yaml lib\\",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "axios": "^1.14.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^4.8.0",
    "googleapis": "^171.4.0",
    "swagger-ui-express": "^5.0.0",
    "xml2js": "^0.6.2",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/xml2js": "^0.4.14",
    "@types/yamljs": "^0.2.34",
    "typescript": "^5.4.2"
  },
  "private": true
}
