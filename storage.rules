rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // Identity Profile Images
    match /users/{userId}/avatar {
      // Any authenticated user on the entire OS can read the directory profile images
      allow read: if request.auth != null;
      
      // Only the user themselves, or an authorized manager/owner can upload a new avatar
      allow write: if request.auth != null && (
        request.auth.uid == userId ||
        request.auth.token.role in ['business_owner', 'manager', 'super_admin']
      );
    }

    // Feedback Screenshots
    match /feedback_screenshots/{fileName} {
      allow read: if true;
      allow write: if request.resource.size < 5 * 1024 * 1024 
                   && request.resource.contentType.matches('image/.*');
    }

    // Facility Maps Base Images
    match /facility_maps/{tenantId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (
        request.auth.token.tenantId == tenantId || request.auth.token.role == 'super_admin'
      );
    }

    // Job Media Files
    match /tenants/{tenantId}/jobs/{fileName} {
      allow read: if request.auth != null && (request.auth.token.tenantId == tenantId || request.auth.token.role == 'super_admin');
      allow create, update: if request.auth != null && (request.auth.token.tenantId == tenantId || request.auth.token.role == 'super_admin') 
                            && request.resource.size < 30 * 1024 * 1024;
      allow delete: if request.auth != null && (request.auth.token.tenantId == tenantId || request.auth.token.role == 'super_admin');
    }

    // CompanyCam Media Mirror / Direct Job Uploads
    match /job_media/{tenantId}/{jobId}/{fileName} {
      allow read: if true; // CompanyCam needs public URLs to ingest them
      allow create, update, delete: if request.auth != null && (
        request.auth.token.tenantId == tenantId || 
        request.auth.token.role == 'super_admin' || 
        request.auth.token.role == 'system_owner'
      );
    }

    // Business Global Brand Media
    match /businesses/{tenantId}/{fileName} {
      allow read: if true; // Icons need to be globally readable to render the PWA App Install splash screen
      allow write: if request.auth != null && (
        request.auth.token.role in ['system_owner', 'super_admin'] ||
        (request.auth.token.tenantId == tenantId && request.auth.token.role in ['business_owner', 'manager'])
      );
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
